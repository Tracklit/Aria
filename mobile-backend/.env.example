NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/aria
JWT_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:8081

# Apple Sign-In
# Comma-separated audiences accepted in Apple identity tokens.
# Usually your iOS bundle identifier, e.g. com.aria.coaching
APPLE_SIGN_IN_AUDIENCES=com.aria.coaching

# Google Sign-In
# Comma-separated Google OAuth client IDs accepted as token audiences.
GOOGLE_OAUTH_CLIENT_IDS=
# Optional explicit vars (included in accepted audiences automatically)
GOOGLE_OAUTH_IOS_CLIENT_ID=
GOOGLE_OAUTH_ANDROID_CLIENT_ID=
GOOGLE_OAUTH_WEB_CLIENT_ID=

# AI backend
ARIA_API_URL=https://ca-aria-api-prod.bravepond-d57ce243.westus.azurecontainerapps.io

# Azure Blob Storage (profile images)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=profile-images
AZURE_STORAGE_CONNECTION_STRING=
