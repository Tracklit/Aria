{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "appName": {
      "value": "aria"
    },
    "environment": {
      "value": "dev"
    },
    "location": {
      "value": "eastus"
    },
    "containerRegistryName": {
      "value": "acraria<uniquesuffix>"
    },
    "pythonApiImage": {
      "value": "aria-api:latest"
    },
    "nodeApiImage": {
      "value": "aria-mobile-backend:latest"
    },
    "pythonApiMinReplicas": {
      "value": 0
    },
    "pythonApiMaxReplicas": {
      "value": 2
    },
    "nodeApiMinReplicas": {
      "value": 0
    },
    "nodeApiMaxReplicas": {
      "value": 2
    },
    "deployAzureOpenAI": {
      "value": true
    },
    "openAIModelDeployments": {
      "value": [
        {
          "name": "gpt-4o-mini",
          "model": "gpt-4o-mini",
          "version": "2024-07-18",
          "capacity": 30
        }
      ]
    },
    "deployAzureSpeech": {
      "value": true
    },
    "deployAzureTranslator": {
      "value": false
    },
    "deployAzureCommunication": {
      "value": false
    },
    "existingKeyVaultName": {
      "value": "kv-tracklit-dev-kvnx2h"
    },
    "existingKeyVaultResourceGroup": {
      "value": "rg-tracklit-dev"
    },
    "existingPostgresServerName": {
      "value": "pg-tracklit-dev-kvnx2h"
    },
    "existingPostgresResourceGroup": {
      "value": "rg-tracklit-dev"
    },
    "existingRedisCacheName": {
      "value": "redis-tracklit-dev-kvnx2h"
    },
    "existingRedisResourceGroup": {
      "value": "rg-tracklit-dev"
    }
  }
}
