{
  "expo": {
    "name": "Aria",
    "slug": "Aria",
    "scheme": "aria",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D12"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aria.mobile",
      "usesAppleSignIn": true,
      "appleTeamId": "2V636U3DWT",
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon-dark.png"
      },
      "buildNumber": "18",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Aria needs access to your photo library to upload a profile picture.",
        "NSMicrophoneUsageDescription": "Aria needs microphone access for voice input to your AI coach.",
        "NSSpeechRecognitionUsageDescription": "Aria uses speech recognition to let you talk to your AI coach hands-free.",
        "NSHealthShareUsageDescription": "Aria reads your health data (heart rate, sleep, workouts, steps) to personalize training insights and recovery recommendations.",
        "NSHealthUpdateUsageDescription": "Aria saves workout data to Apple Health so all your training is in one place.",
        "UIBackgroundModes": ["fetch", "processing"]
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": ["health-records"]
      }
    },
    "android": {
      "package": "com.aria.coaching",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D12"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-video",
      "expo-apple-authentication",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0D0D12"
        }
      ],
      [
        "react-native-health",
        {
          "isClinicalDataEnabled": false
        }
      ]
    ]
  }
}
