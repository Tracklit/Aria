{
  "expo": {
    "name": "Aria",
    "slug": "Aria",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D12"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aria.coaching",
      "appleTeamId": "2V636U3DWT",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Aria needs access to your photo library to upload a profile picture.",
        "NSSpeechRecognitionUsageDescription": "Aria uses speech recognition to let you talk to your AI coach hands-free."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D12"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-video",
      "expo-apple-authentication"
    ]
  }
}
