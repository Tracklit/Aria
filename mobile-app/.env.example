# Mobile API endpoints
EXPO_PUBLIC_MOBILE_BACKEND_BASE_URL=https://ca-aria-mobile-prod.calmcliff-31ba567d.westus.azurecontainerapps.io
EXPO_PUBLIC_AI_API_BASE_URL=https://ca-aria-api-prod.calmcliff-31ba567d.westus.azurecontainerapps.io

# Google Sign-In OAuth client IDs (from Google Cloud Console)
